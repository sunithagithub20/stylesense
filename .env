# Gemini API key (for image vision / skin tone analysis)
# Get free at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (for fast LLM text generation)
# Get free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face API token (for style classification + fallback generation)
# Get free at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here

# IBM watsonx.ai credentials (for IBM Granite model)
# Get at: https://www.ibm.com/watsonx
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
